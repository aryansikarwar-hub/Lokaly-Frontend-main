# =============================================================
# Lokaly frontend (React + Vite)
# =============================================================
# Copy to `.env.local` for local dev. On Vercel, set these in the
# Project -> Settings -> Environment Variables UI.
#
# IMPORTANT: Vite only exposes vars prefixed with VITE_ to the
# browser. Do NOT put any secrets here — everything in this file
# ships in the JS bundle.

# Backend API base URL.
# Local dev:  http://localhost:5050/api   (when running backend on 5050)
# Production: https://<your-render-backend>.onrender.com/api
VITE_API_URL=http://localhost:5050/api
